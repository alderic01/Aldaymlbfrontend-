export async function handler(event) {
  const ANTHROPIC_API_KEY = process.env.ANTHROPIC_API_KEY;

  if (!ANTHROPIC_API_KEY) {
    return {
      statusCode: 500,
      body: JSON.stringify({ error: "ANTHROPIC_API_KEY not configured" })
    };
  }

  let body = {};
  try {
    body = event.body ? JSON.parse(event.body) : {};
  } catch {
    body = {};
  }

  const { games = [], date = "", mode = "picks" } = body;

  const slateContext = games.length
    ? games.map(g =>
        `${g.away?.abbr} @ ${g.home?.abbr} | Venue: ${g.venue?.name} | ` +
        `Away P: ${g.awayPitcher?.name} (ERA ${g.awayPitcher?.era}, WHIP ${g.awayPitcher?.whip}) | ` +
        `Home P: ${g.homePitcher?.name} (ERA ${g.homePitcher?.era}, WHIP ${g.homePitcher?.whip})`
      ).join("\n")
    : "No slate data — give general MLB DFS advice for today.";

  const prompts = {
    picks: `You are an elite MLB DFS analyst. Given today's slate, provide sharp concise picks.

SLATE (${date}):
${slateContext}

Respond with:
1. TOP STACK (best team to stack, why)
2. TOP ONE-OFF HITTER (best GPP one-off, why)
3. PITCHER TO TARGET (best SP play, why)
4. PITCHER TO FADE (avoid, why)
5. MARKET ALERT (sharp observation about the slate)

Be direct and specific. No fluff.`,

    stacks: `You are an elite MLB DFS GPP stack specialist.

SLATE (${date}):
${slateContext}

Rank top 3 GPP stacks. For each:
- Team and opposing pitcher
- Core 3-4 hitters to target
- Why this stack (park, pitcher weakness, weather)
- Correlation play to add`,

    edges: `You are a sharp MLB betting edge finder.

SLATE (${date}):
${slateContext}

Identify 3 sharp edges:
- One total edge (over/under and why)
- One moneyline value spot (and why)
- One DFS leverage play (low-owned upside player)

2-3 sentences each. Be direct.`
  };

  try {
    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "x-api-key": ANTHROPIC_API_KEY,
        "anthropic-version": "2023-06-01"
      },
      body: JSON.stringify({
        model: "claude-sonnet-4-5-20250929",
        max_tokens: 1024,
        messages: [
          { role: "user", content: prompts[mode] || prompts.picks }
        ]
      })
    });

    if (!response.ok) {
      return {
        statusCode: 502,
        body: JSON.stringify({ error: `Anthropic error: ${response.status}` })
      };
    }

    const data = await response.json();

    return {
      statusCode: 200,
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        ok: true,
        mode,
        date,
        analysis: data.content?.[0]?.text || ""
      })
    };
  } catch (e) {
    return {
      statusCode: 500,
      body: JSON.stringify({ error: e.message })
    };
  }
}
